{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "ext/dev-template-php",
  "description": "PHP Project Template",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/init-templates/php",
  "keywords": [
    "php",
    "project",
    "template"
  ],
  "authors": [
    {
      "name": "Cloudflying",
      "email": "oss@live.hk",
      "homepage": "https://github.com/imxieke",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "phpunit/phpunit": "^12.5.12",
    "phpstan/phpstan": "^2.1.21",
    "symfony/var-dumper": "^7.2.0",
    "vimeo/psalm": "^6.15.0"
  },
  "autoload": {
    "psr-4": {
      "Zeus\\": "src/"
    },
    "files": []
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors",
    "psalm": "psalm --show-info=true --no-cache",
    "psalm-fix": "psalm --no-cache --alter --issues=MissingReturnType,MissingParamType",
    "phpstan": "vendor/bin/phpstan analyze src/ --memory-limit 512M --level 9"
  },
  "scripts-descriptions": {
    "test": "Run all tests."
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "process-timeout": 300,
    "optimize-autoloader": true
  }
}
